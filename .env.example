# ===================== vulneraciones-service (SMID 6.5) — variables de entorno =====================
# Copiar a .env y completar. NO subir .env con secretos reales al control de versiones.

# --- Base de datos (MySQL 8) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_vulneraciones
DB_USER=smid
DB_PASSWORD=cambieme

# --- JWT (compartido con el clúster SMID) ---
# Secreto HS256 en UTF-8, >= 32 bytes. Obligatorio.
JWT_SECRET=clave-compartida-del-cluster-smid-de-al-menos-32-bytes
JWT_ISSUER=smid-auth
JWT_AUDIENCE=smid-servicios
JWT_KID_ACTIVO=smid-2026-06
# Par opcional para rotación de clave:
JWT_KID_PREVIO=
JWT_SECRET_PREVIO=

# --- Roles habilitantes (listas separadas por coma) ---
ROLES_COORDINACION=COORDINADOR,COORDINACION,ADMIN_SEDE,ADMIN_NACIONAL
ROLES_ACCESO_RESERVADO=COORDINADOR,ADMIN_SEDE,ADMIN_NACIONAL

# --- Numeración FIR ---
FIR_INICIO_OFICIAL=2027-01-01
SEDE_CODIGO_DEFECTO=SD

# --- Datos reservados en reposo (DT-1) ---
# aes-gcm (producción) | none (solo desarrollo con datos sintéticos)
RESERVADO_CIFRADO=aes-gcm
# Clave AES-256 en Base64 (32 bytes) cuando RESERVADO_CIFRADO=aes-gcm:
RESERVADO_CLAVE=

# --- RabbitMQ ---
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBIT_VHOST=/

# --- Mensajería de dominio ---
# rabbitmq | log   (publicación) / rabbitmq | none  (consumo)
EVENTOS_TRANSPORTE=rabbitmq
EVENTOS_CONSUMO=rabbitmq
EVENTOS_EXCHANGE=smid.eventos
EVENTOS_COLA_CASO_ABIERTO=vulneraciones.caso-abierto
EVENTOS_DLX=vulneraciones.dlx
EVENTOS_DLQ_CASO_ABIERTO=vulneraciones.caso-abierto.dlq
EVENTOS_ROUTING_CASO_ABIERTO=caso.abierto

# --- Enriquecimiento on-demand (opcional; desactivado por defecto) ---
ENRIQUECIMIENTO_CASOS_ACTIVO=false
ENRIQUECIMIENTO_PERSONAS_ACTIVO=false
ENRIQUECIMIENTO_CATALOGO_ACTIVO=false
CASOS_URL=http://localhost:8090/api
PERSONAS_URL=http://localhost:8088/api
CATALOGO_URL=http://localhost:8087/api
